<UserControl x:Class="LabelPrinter.Controls.TextPrintableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="Gray" BorderThickness="1" Padding="6" Margin="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Text" FontWeight="Bold" Margin="0,0,0,4" />

            <Grid Grid.Row="1" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Text" Width="48" VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="64" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Font" Width="48" VerticalAlignment="Center" />
                <ComboBox x:Name="FontFamilyCombo"
                          Grid.Column="1"
                          SelectedValuePath="Source"
                          SelectedValue="{Binding FontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Source}" FontFamily="{Binding}" VerticalAlignment="Center" />
                                <TextBlock Text="AaBb" FontFamily="{Binding}" Margin="8,0,0,0" Foreground="Gray" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Grid.Column="2" Text="Size" VerticalAlignment="Center" Margin="8,0,6,0" />
                <TextBox Grid.Column="3"
                         Text="{Binding FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="H Align" Width="48" VerticalAlignment="Center" />
                <ComboBox x:Name="HorizontalAlignmentCombo"
                          Grid.Column="1"
                          SelectedItem="{Binding HorizontalTextAlignment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="2" Text="V Align" VerticalAlignment="Center" Margin="8,0,6,0" />
                <ComboBox x:Name="VerticalAlignmentCombo"
                          Grid.Column="3"
                          SelectedItem="{Binding VerticalTextAlignment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Grid.Column="1" Text="{Binding XMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
                <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Margin="6,0,4,0" />
                <TextBox Grid.Column="3" Text="{Binding YMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
                <TextBlock Grid.Column="4" Text="W" VerticalAlignment="Center" Margin="6,0,4,0" />
                <TextBox Grid.Column="5" Text="{Binding WidthMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
                <TextBlock Grid.Column="6" Text="H" VerticalAlignment="Center" Margin="6,0,4,0" />
                <TextBox Grid.Column="7" Text="{Binding HeightMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
                <TextBlock Grid.Column="8" Text="Rot" VerticalAlignment="Center" Margin="6,0,4,0" />
                <TextBox Grid.Column="9" Text="{Binding RotationDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
