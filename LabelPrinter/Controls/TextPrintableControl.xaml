<UserControl x:Class="LabelPrinter.Controls.TextPrintableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
             xmlns:models="clr-namespace:LabelPrinter.Models"
             Height="170" Width="300">
    <Border BorderBrush="Gray" BorderThickness="1" Padding="4" Margin="2">
        <StackPanel>
            <TextBlock Text="Text" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Text:" Width="50" VerticalAlignment="Center" />
                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Font:" Width="50" />
                <ComboBox Width="160"
                          ItemsSource="{x:Static media:Fonts.SystemFontFamilies}"
                          SelectedValuePath="Source"
                          SelectedValue="{Binding FontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Source}" FontFamily="{Binding}" VerticalAlignment="Center" />
                                <TextBlock Text="  AaBb" FontFamily="{Binding}" Margin="8,0,0,0" Foreground="Gray" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="Size:" Width="40" Margin="8,0,0,0" />
                <TextBox Text="{Binding FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="40" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock Text="H Align:" Width="60" VerticalAlignment="Center" />
                <ComboBox SelectedValue="{Binding HorizontalTextAlignment, Mode=TwoWay}" SelectedValuePath="Tag" Width="110">
                    <ComboBoxItem Tag="{x:Static TextAlignment.Left}">Left</ComboBoxItem>
                    <ComboBoxItem Tag="{x:Static TextAlignment.Center}">Center</ComboBoxItem>
                    <ComboBoxItem Tag="{x:Static TextAlignment.Right}">Right</ComboBoxItem>
                    <ComboBoxItem Tag="{x:Static TextAlignment.Justify}">Justify</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="V Align:" Width="60" Margin="8,0,0,0" VerticalAlignment="Center" />
                <ComboBox SelectedValue="{Binding VerticalTextAlignment, Mode=TwoWay}" SelectedValuePath="Tag" Width="80">
                    <ComboBoxItem Tag="{x:Static models:VerticalTextAlignment.Top}">Top</ComboBoxItem>
                    <ComboBoxItem Tag="{x:Static models:VerticalTextAlignment.Center}">Center</ComboBoxItem>
                    <ComboBoxItem Tag="{x:Static models:VerticalTextAlignment.Bottom}">Bottom</ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="X:" Width="20" />
                <TextBox Text="{Binding X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                <TextBlock Text="Y:" Width="20" />
                <TextBox Text="{Binding Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                <TextBlock Text="W:" Width="20" />
                <TextBox Text="{Binding Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                <TextBlock Text="H:" Width="20" />
                <TextBox Text="{Binding Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>